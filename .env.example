# ==========================================
# Application Environment Variables Example
# ==========================================
# This file serves as a template for environment variables needed to run the application.
# Copy this file to '.env' and replace the placeholder values with your actual credentials.
# Make sure NOT to commit your actual '.env' file to version control.

# ------------------------------------------
# Database Configuration
# ------------------------------------------
# Main database connection string for PostgreSQL instance used by Prisma ORM.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://username:password@localhost:5432/trading_agent_db?schema=public"

# ------------------------------------------
# Server Configuration
# ------------------------------------------
# The port number the Express application server will listen on.
PORT=3000
# The environment mode (development, test, or production).
# Controls logging verbosity, error stack traces, and optimization flags.
NODE_ENV=development

# ------------------------------------------
# CORS Configuration
# ------------------------------------------
# Allowed origins for Cross-Origin Resource Sharing (CORS) requests.
# Restricts which domains can make API requests to this backend.
CORS_ORIGIN=http://localhost:3000

# ------------------------------------------
# External API Integrations
# ------------------------------------------

# Google Gemini AI - REQUIRED
# Used for the intelligent chatbot, investment advice, and search grounding.
# Get your API key from: https://aistudio.google.com/app/apikey (Free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# HuggingFace - REQUIRED
# Used for natural language processing and financial sentiment analysis (FinBERT model).
# Get your API key from: https://huggingface.co/settings/tokens (Free tier available)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ------------------------------------------
# News API Providers (Choose ONE required)
# ------------------------------------------

# Option 1: NewsAPI.org
# Used to fetch real-time market and financial news (100 requests/day free).
# Get your API key from: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Option 2: GNews API (Alternative to NewsAPI)
# Can be used instead of NewsAPI (100 requests/day free).
# Get your API key from: https://gnews.io/register
GNEWS_API_KEY=your_gnews_api_key_here

# Option 3: Currents API (Alternative news source)
# Get your API key from: https://currentsapi.services/en/register
CURRENTS_API_KEY=your_currents_api_key_here

# ------------------------------------------
# Market Data Providers
# ------------------------------------------

# CoinGecko API - OPTIONAL
# Used for fetching real-time cryptocurrency prices and market data.
# Leave empty to use the free tier without authentication (10-50 calls/minute limit).
# For higher limits, get an API key: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# Gold API - REQUIRED
# Used for fetching real-time precious metals (Gold/Silver) spot prices.
# Get your API key from: https://www.goldapi.io/dashboard
GOLD_API_KEY=your_gold_api_key_here

# ------------------------------------------
# Caching Configuration
# ------------------------------------------
# The Time-To-Live (TTL) for cached items in seconds.
CACHE_TTL=300
# How frequently (in seconds) the cache should automatically check for expired items.
CACHE_CHECK_PERIOD=600

# ------------------------------------------
# Rate Limiting Configuration
# ------------------------------------------
# Time window for rate limiting in milliseconds (default: 15 minutes = 900000ms).
RATE_LIMIT_WINDOW_MS=900000
# Maximum number of allowed requests per IP within the rate limit window.
RATE_LIMIT_MAX_REQUESTS=100

# ------------------------------------------
# Application Logging
# ------------------------------------------
# Minimum log level to output (e.g., error, warn, info, debug).
# Using 'info' in production and 'debug' in development is recommended.
LOG_LEVEL=info
